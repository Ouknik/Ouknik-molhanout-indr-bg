APP_NAME=Molhanout
APP_ENV=local
APP_KEY=base64:GENERATE_A_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=molhanout
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Pusher Configuration (required for real-time features)
PUSHER_APP_ID=your_app_id
PUSHER_APP_KEY=your_app_key
PUSHER_APP_SECRET=your_app_secret
PUSHER_APP_CLUSTER=eu
PUSHER_SCHEME=https

# Or use self-hosted with Laravel Reverb
# REVERB_APP_ID=your_reverb_id
# REVERB_APP_KEY=your_reverb_key
# REVERB_APP_SECRET=your_reverb_secret
# REVERB_HOST=localhost
# REVERB_PORT=8080

SANCTUM_STATEFUL_DOMAINS=localhost

FIREBASE_CREDENTIALS=firebase-credentials.json
FIREBASE_DATABASE_URL=

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@molhanout.ma"
MAIL_FROM_NAME="${APP_NAME}"

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_AVAILABLE_LOCALES=ar,fr,en
