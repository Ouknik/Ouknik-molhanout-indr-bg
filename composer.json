{
    "name": "molhanout/wholesale-marketplace",
    "type": "project",
    "description": "B2B Wholesale Marketplace - Reverse Bidding Platform for Moroccan Grocery Shops",
    "keywords": ["laravel", "b2b", "wholesale", "marketplace"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "intervention/image": "^3.0",
        "kreait/laravel-firebase": "^5.0",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "pusher/pusher-php-server": "*",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-translatable": "^6.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
